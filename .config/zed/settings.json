// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "button": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "project_panel": {
    "bold_folder_labels": true,
    "indent_size": 35.0,
    "entry_spacing": "comfortable",
    "default_width": 470.0,
    "dock": "left"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "terminal": {
    "max_scroll_history_lines": 50000,
    "default_height": 600.0
  },
  "calls": {
    "mute_on_join": true
  },
  "proxy": "",
  "disable_ai": true,
  "horizontal_scroll_margin": 2.0,
  "vertical_scroll_margin": 1.0,
  "scroll_sensitivity": 1.0,
  "fast_scroll_sensitivity": 3.0,
  "agent_ui_font_size": 24.0,
  "prettier": {
    "parser": "",
    "allowed": true
  },
  "autosave": "on_focus_change",
  "buffer_font_weight": 400.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 25.0,
  "buffer_font_size": 23.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
}
